# 本地 HTTP 服务：检索、POST /save 写素材、POST /summarize（供扩展与 OpenClaw / curl）
WIKI_BRIDGE_PORT=3456
# 必填：本机 bridge 的 X-API-Key（openssl rand -hex 32 之类随机串）

WIKI_BRIDGE_API_KEY=change-me-to-a-long-random-string

# AI 摘要（POST /summarize），扩展「AI 摘要」按钮会调用本机 bridge
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=
# DeepSeek 示例（勿把真密钥提交仓库）：OPENAI_BASE_URL=https://api.deepseek.com/v1
# OPENAI_MODEL=deepseek-chat
