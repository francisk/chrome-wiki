{
  "manifest_version": 3,
  "name": "知识随手抓",
  "version": "1.0",
  "description": "保存当前页标题/链接/摘要到本地数据库，可选 AI 摘要与标签；经本机 HTTP bridge 写入 JSONL。",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "保存素材",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "24": "icons/icon24.png",
      "32": "icons/icon32.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "omnibox": {
    "keyword": "s"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "permissions": ["activeTab", "scripting", "tabs", "storage"],
  "host_permissions": ["http://127.0.0.1/*", "http://localhost/*"]
}
